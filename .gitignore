# scripts/build_features*.py + the eval scripts — attn/synth/tsfm/bocpd/tcn/pit
# caches, etc.). Never pushed; trained model weights live under artifacts/ instead.
features/*.npz

# deploy local-test prediction output (regenerated every crunch test / infer)
structural-break-real-time-chinchilla/prediction/

# round-7 negative-result: local-only TSFM weights (Chronos-T5-mini, 78MB,
# downloaded via curl; NOT bundled into the cloud submission — serving stays
# pure-numpy). torch/chronos are local-only too (never in cloud requirements).
models/

# round-6 negative-result heavy artifact: ExtraTrees joblib (252MB, reproducible
# via scripts/finalize_et.py — keep only meta.json under version control)
artifacts/models/model_030_extratrees/model.joblib

